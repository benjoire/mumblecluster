# MumbleCluster storage-host claim profile

# physical storage identity
DEVICE_UUID="REPLACE_DEVICE_UUID"
MOUNTPOINT="/srv/mc-pvcstore"

# cluster label used to mark the active storage host
HOST_LABEL_KEY="mumblecluster.io/pvcstore-host"
HOST_LABEL_VALUE="true"

# export networks
LAN_CIDR="REPLACE_LAN_CIDR"
WG_CIDR="REPLACE_WG_CIDR"

# kube access
KUBECONFIG_PATH="/etc/rancher/rke2/rke2.yaml"

# WG-safe provisioner
WG_PROVISIONER_NAMESPACE="mc-pvcstore"
WG_PROVISIONER_DEPLOY="mc-pvcstore-wg-nfs-provisioner"

# quorum-3 storage-host candidates
CLAIMANT_NODES=("controller-a" "controller-b" "controller-c")

# canary validation lane
CANARY_NAMESPACE="app-desk"
CANARY_POD_NAME="wg-canary-pod"
CANARY_PVC_NAMES=("wg-canary-pvc" "wg-canary-pod-config")
CANARY_PVC_MANIFESTS=("22-app-desk-wg-canary-pvc.yaml" "24-wg-canary-config-pvc.yaml")
CANARY_POD_MANIFEST="23-app-desk-wg-canary-pod.yaml"

# behavior
AUTO_WRITE_EXPORTS="${AUTO_WRITE_EXPORTS:-0}"
CANARY_WAIT_SECONDS="${CANARY_WAIT_SECONDS:-180}"
PVC_WAIT_SECONDS="${PVC_WAIT_SECONDS:-120}"
